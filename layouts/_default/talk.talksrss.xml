{{- $data := partial "helpers/talks-data.html" . -}}
{{- $moments := $data.moments -}}
{{- $channelTitle := cond (eq .Language.Lang "zh-cn") "老T 说说" "Lawtee Talks" -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>\n" | safeHTML -}}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/">
  <channel>
    <title>{{ $channelTitle }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ $channelTitle }}</description>
    <generator>Hugo</generator>
    <language>{{ .Language.LanguageCode | default .Language.Lang }}</language>
    <lastBuildDate>{{ now.UTC.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ printf "%stalks.xml" .Permalink }}" rel="self" type="application/rss+xml" />
    {{- range first 20 $moments }}
    {{- $timeSource := .time | replaceRE " " "T" -}}
    {{- if not (findRE ":[0-9]{2}:[0-9]{2}" $timeSource) -}}
      {{- $timeSource = printf "%s:00+08:00" $timeSource -}}
    {{- end -}}
    {{- $published := time.AsTime $timeSource -}}
    {{- $itemLink := printf "%s#%s" $.Permalink ($published.Format "200601021504") -}}
    {{- $rendered := $.RenderString .content -}}
    {{- $rendered = replace $rendered "]]>" "]]]]><![CDATA[>" -}}
    <item>
      <title>{{ .title }}</title>
      <link>{{ $itemLink }}</link>
      <guid isPermaLink="true">{{ $itemLink }}</guid>
      <pubDate>{{ $published.UTC.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <description>{{ .content | plainify | htmlEscape }}</description>
      {{ printf "<content:encoded><![CDATA[%s]]></content:encoded>" $rendered | safeHTML }}
    </item>
    {{- end }}
  </channel>
</rss>
